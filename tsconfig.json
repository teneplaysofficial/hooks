{
  "compilerOptions": {
    "target": "es2024",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["DOM", "ES2024"],
    "declaration": true,
    "declarationDir": "dist/types",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "jsx": "react",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node", "vitest"]
  },
  "include": ["src", "scripts"],
  "exclude": ["node_modules", "**/*.test.ts"]
}
